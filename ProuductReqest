const BASE_URL = "https://panda-market-api-crud.vercel.app/products";

/**
 * 반환 형식: { total, page, pageSize, list: [...] } 같은 원시 응답 객체를 반환합니다.
 */

export async function getProductList(params = { page: 1, pageSize: 10, keyword: "" }) {
  try {
    const url = new URL(BASE_URL);
    Object.keys(params).forEach(k => {
      if (params[k] !== undefined && params[k] !== "") url.searchParams.set(k, params[k]);
    });

    const resp = await fetch(url.toString());
    if (!resp.ok) {
      console.error("getProductList: 응답 오류", resp.status);
      return null;
    }
    return await resp.json();
  } catch (err) {
    console.error("getProductList Error:", err.message);
    return null;
  }
}

export async function getProduct(id) {
  try {
    const resp = await fetch(`${BASE_URL}/${id}`);
    if (!resp.ok) {
      console.error("getProduct: 응답 오류", resp.status);
      return null;
    }
    return await resp.json();
  } catch (err) {
    console.error("getProduct Error:", err.message);
    return null;
  }
}

export async function createProduct(productData) {
  try {
    const resp = await fetch(BASE_URL, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(productData),
    });
    if (!resp.ok) {
      console.error("createProduct: 응답 오류", resp.status);
      return null;
    }
    return await resp.json();
  } catch (err) {
    console.error("createProduct Error:", err.message);
    return null;
  }
}

