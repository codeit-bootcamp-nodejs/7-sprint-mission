  try {
    const resp = await fetch(`${BASE_URL}/${id}`, {
      method: "PATCH",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(updatedData),
    });
    if (!resp.ok) {
      console.error("patchProduct: 응답 오류", resp.status);
