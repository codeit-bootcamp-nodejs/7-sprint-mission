{
    "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
    "features": {
        "ghcr.io/devcontainers/features/postgres:1": {
            "version": "latest",
            "databaseName": "postgres",
            "adminPassword": "postgres"
        }
        
